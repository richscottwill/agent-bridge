#!/usr/bin/env bash
# Git Sync — push/pull shared/ and .kiro/ to personal git remote
# Usage: sync.sh [push|pull|status]

set -euo pipefail

REPO_DIR="/shared/user"
TIMESTAMP=$(date -u +"%Y-%m-%d %H:%M UTC")

cd "$REPO_DIR"

case "${1:-status}" in
  push)
    # Pull first to pick up any changes from Kiro (local)
    echo "→ Pulling before push (avoid conflicts with Kiro)..."
    git stash --quiet 2>/dev/null || true
    if ! git pull origin main --rebase; then
      echo "✗ Pull failed — check auth or network. Unstashing."
      git stash pop --quiet 2>/dev/null || true
      exit 1
    fi
    git stash pop --quiet 2>/dev/null || true

    echo "→ Adding tracked files..."
    git add -A
    
    # Check if there's anything to commit
    if git diff --cached --quiet 2>/dev/null; then
      echo "✓ Nothing to push — working tree clean."
      exit 0
    fi
    
    echo "→ Committing..."
    git commit -m "sync: $TIMESTAMP"
    
    echo "→ Pushing to remote..."
    if ! git push -u origin main; then
      echo "✗ Push failed — credentials may have expired. Run: git -C $REPO_DIR push -u origin main"
      exit 1
    fi
    
    echo "✓ Pushed successfully."
    ;;
    
  pull)
    echo "→ Pulling from remote..."
    git pull origin main --rebase
    echo "✓ Pulled successfully."
    ;;
    
  status)
    echo "=== Git Sync Status ==="
    echo ""
    echo "Remote:"
    git remote -v 2>/dev/null || echo "  (no remote configured)"
    echo ""
    echo "Branch:"
    git branch -v 2>/dev/null || echo "  (no commits yet)"
    echo ""
    echo "Changed files:"
    git status --short shared/ .kiro/ 2>/dev/null || echo "  (no changes)"
    ;;
    
  *)
    echo "Usage: sync.sh [push|pull|status]"
    exit 1
    ;;
esac
