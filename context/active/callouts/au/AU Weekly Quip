SELECT
nva.account_verified_date,
nva.feature_name,
CASE WHEN CAA.business_tier_new IN ('SSR', 'SMB') THEN CAA.business_tier_new ELSE 'CPS' END as Business_classification,
CASE
WHEN nva.marketplace_id = '1' THEN 'US'
WHEN nva.marketplace_id = '7' THEN 'CA'
WHEN nva.marketplace_id = '3' THEN 'UK'
WHEN nva.marketplace_id = '4' THEN 'DE'
WHEN nva.marketplace_id = '5' THEN 'FR'
WHEN nva.marketplace_id = '35691' THEN 'IT'
WHEN nva.marketplace_id = '44551' THEN 'ES'
WHEN nva.marketplace_id = '6' THEN 'JP'
WHEN nva.marketplace_id = '771770' THEN 'MX'
WHEN nva.marketplace_id = '111172' THEN 'AU'
ELSE 'No Country Found'
END AS Market_Country,
count(distinct nva.business_account_id)
from abbd_sandbox_mktg.ab_acq_channel_attr nva
left join abbd_sandbox_mktg.ab_business_accts_agg_metrics CAA --- ABMA-1679
on nva.BUSINESS_ACCOUNT_ID = CAA.BUSINESS_ACCOUNT_ID
and nva.marketplace_id = caa.marketplace_id
where nva.is_abuse = 0
and nva.overall_status in ('VERIFIED_POSITIVE','WHITELISTED')
and nva.channel = 'Paid Search'
and nva.marketplace_id IN (1,7, 3,4,5,35691,44551,771770,6,111172)
and nva.account_verified_date BETWEEN '20250608' and '20250614'
----and is_active = 1
group by 1,2,3,4
order by 1

