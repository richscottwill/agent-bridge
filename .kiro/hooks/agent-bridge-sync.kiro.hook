{
  "name": "4 \u00b7 Agent Bridge Sync (on-demand)",
  "version": "2",
  "description": "Sync ~/shared/ to GitHub agent-bridge repo. Process agent-bus forum.",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Protocol: ~/shared/.kiro/agents/body-system/agent-bridge-sync.md. Step 0: process agent-bus (surface non-kiro-server posts to agent-bus-inbox.md, regenerate dashboard + feed.md, archive stale). Step 1-2: scan for new files, update CHANGELOG. Step 3: git pull --rebase --autostash \u2192 add -A \u2192 commit \u2192 push to origin/main. Step 4: quality check. Doomsday mentality \u2014 the repo IS the survival kit."
  }
}
