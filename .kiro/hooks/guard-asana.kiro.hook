{
  "name": "Guard: Asana",
  "version": "1.0.0",
  "description": "Enforces Asana write guardrails via preToolUse. Classifies read vs write, checks ownership, enforces whitelist.",
  "when": {
    "type": "preToolUse",
    "toolTypes": ["@mcp.*asana.*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "ASANA GUARDRAIL. READ ops (Get/Search/List/read/find/query) → ACCESS GRANTED. WRITE ops (UpdateTask, CreateTask, CreateTaskStory, SetParentForTask, AddTagForTask, RemoveTagForTask): if assignee GID = 1212732742544167 (Richard) → ACCESS GRANTED, else → ACCESS DENIED, block call. Log decision."
  }
}