{
  "name": ".AM-Triage: Curate + Draft",
  "version": "1.0.0",
  "description": "Interactive morning triage: intake signals, task enrichment, pipeline/portfolio scan, proposals for approval.",
  "when": { "type": "userTriggered" },
  "then": {
    "type": "askAgent",
    "prompt": "Run the interactive morning triage.\n\nExecute ~/shared/context/protocols/am-triage.md.\n\nPresent ALL proposals for approval before writing. No Asana writes without explicit approval. Follow Guardrail Protocol in asana-command-center.md."
  }
}
