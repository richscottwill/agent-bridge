{
  "enabled": true,
  "name": "Guard: Calendar",
  "version": "2",
  "description": "Blocks calendar events with external attendees. Personal blocks allowed.",
  "when": {
    "type": "preToolUse",
    "toolTypes": [".*calendar_meeting.*", ".*calendar_event.*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Inspect ALL attendee/participant fields (attendees, requiredAttendees, optionalAttendees, resources).\n\nIF creating/updating AND either (a) NO attendees listed (personal block), or (b) ONLY attendee is prichwil@amazon.com → ACCESS GRANTED. Proceed.\n\nIF ANY attendee other than prichwil exists → ACCESS DENIED. Do NOT proceed. Tell Richard who would be invited and ask for explicit approval. If approved, retry. Otherwise, create the event without attendees and tell Richard to add them manually."
  }
}
