{
  "enabled": true,
  "name": "Guard: Email",
  "version": "4",
  "description": "Blocks outbound email unless all recipients are Richard's own addresses.",
  "when": {
    "type": "preToolUse",
    "toolTypes": [".*email_reply.*", ".*email_send.*", ".*email_forward.*"]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Inspect ALL recipient fields (to, cc, bcc, toRecipients, ccRecipients, bccRecipients).\n\nRichard's approved addresses: prichwil@amazon.com (or alias prichwil), richscottwill@gmail.com\n\nIF ALL recipients across all fields are one of Richard's approved addresses and NO others exist → ACCESS GRANTED. Proceed with the tool call.\n\nIF ANY recipient is NOT one of Richard's approved addresses → ACCESS DENIED. Do NOT proceed. Tell Richard who the email would go to and ask for explicit 'send' approval. If approved, retry. Otherwise, save as draft via email_draft operation='create'."
  }
}
