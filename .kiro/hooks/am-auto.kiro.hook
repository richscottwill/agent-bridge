{
  "name": "AM-Backend: Ingest + Process",
  "version": "5.1.0",
  "description": "DISABLED 2026-04-21: was firing on every promptSubmit, injecting ~2k tokens of backend orchestration into every chat. Mario/pi thesis: the context must be Richard's. Run AM-backend via scheduled trigger or explicit /am-backend command instead — not as a tax on every conversation. Underlying protocol (~/shared/context/protocols/am-backend-parallel.md) is unchanged and re-enableable.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "no-op — AM-backend is not triggered from chat. Use /am-backend or scheduled run instead."
  },
  "enabled": false,
  "workspaceFolderName": "prichwil",
  "shortName": "am-auto"
}
