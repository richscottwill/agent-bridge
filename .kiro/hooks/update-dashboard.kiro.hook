{
  "enabled": true,
  "name": "On-Demand: Dashboard",
  "description": "Regenerates progress charts HTML dashboard from organ data.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Read ~/shared/tools/progress-charts/README.md first for full context on data sources, parsers, and output structure. Then execute `python3 ~/shared/tools/progress-charts/generate.py` and report what was generated (page count, byte sizes, any parser warnings). If the script fails, diagnose which source file has a format mismatch using the regex patterns documented in the README. Do NOT modify any organ files — this is read-only visualization. Output goes to ~/shared/tools/progress-charts/site/ (5 HTML pages)."
  }
}