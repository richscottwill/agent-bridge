{
  "name": "2 · Sync to SharePoint",
  "version": "1",
  "description": "Wiki-to-SharePoint sync. Dry-run first, confirm, then live.",
  "when": { "type": "userTriggered" },
  "then": {
    "type": "askAgent",
    "prompt": "Dry-run: python3 ~/shared/tools/sharepoint-sync/cli.py --dry-run --mode directory. Show changes. Confirm. If yes, live sync. Show results."
  }
}