{
  "enabled": true,
  "name": "Sync Market Constraints to State Files",
  "description": "After the WBR pipeline writes ~/shared/context/active/state-file-constraints-sync.json, an agent reads it and updates the Constraints (auto) block in each state file on SharePoint.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "shared/context/active/state-file-constraints-sync.json"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Execute state-file constraints sync. Read ~/shared/context/active/state-file-constraints-sync.json for the payload of files to update.\n\nFor each file in the payload's `files` array:\n1. Use sharepoint_read_file with savePath='/tmp/{filename}' and serverRelativeUrl={sharepoint_path} to download current content\n2. Splice the `block` into the content:\n   - If both `start_marker` and `end_marker` exist in content: replace everything between them (inclusive) with `block`\n   - Otherwise: locate all lines matching `^---\\s*$`. State files have 3 such separators in the header area (1st opens front-matter, 2nd closes it, 3rd is between doc H1 and `## Introduction`). Insert `block` immediately after the 3rd occurrence (or after the last available if fewer). Surround the inserted block with one blank line before and after.\n3. Use sharepoint_write_file with libraryName='Documents', folderPath='Kiro-Drive/state-files', fileName={filename}, content={updated_content} to overwrite\n\nReport: 'Synced constraints to N state files: [list]' or specific errors per file. Do not ask for confirmation \u2014 the payload was generated by the WBR pipeline and is authorized to write."
  }
}