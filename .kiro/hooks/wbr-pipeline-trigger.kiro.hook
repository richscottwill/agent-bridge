{
  "enabled": true,
  "name": "WBR Pipeline Auto-Trigger",
  "description": "Detects when a WW Dashboard xlsx is dropped into shared/uploads/sheets/ and runs the full WBR pipeline (ingest \u2192 load \u2192 score \u2192 update priors \u2192 project \u2192 callout signal \u2192 dive update \u2192 report).",
  "version": "2",
  "when": {
    "type": "fileCreated",
    "patterns": [
      "shared/uploads/sheets/*Dashboard*.xlsx"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "A new WW Dashboard xlsx was just dropped into shared/uploads/sheets/. Run the full WBR pipeline on it.\n\nIMPORTANT: Richard is in Pacific Time (America/Los_Angeles). Run `TZ=America/Los_Angeles date` to get the correct local time and derive the current ISO week.\n\n\nReport the full pipeline result to Richard."
  }
}