{
  "enabled": true,
  "name": "On-Demand: PS Audit",
  "description": "Runs paid search daily audit pipeline — pulls data, runs analysis, generates reports.",
  "version": "1",
  "when": {
    "type": "userTriggered"
  },
  "then": {
    "type": "runCommand",
    "command": "python -m paid_search_audit.cli --config paid_search_audit/config.json --output-dir ./reports"
  }
}