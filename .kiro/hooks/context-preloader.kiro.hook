{
  "name": "Context Pre-Loader",
  "version": "1.0.0",
  "description": "Analyzes user prompt to pre-load relevant body organs and context files before agent processing.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "echo \"Prompt received. Context pre-loading delegated to auto-inclusion steering files.\""
  }
}