{
  "enabled": true,
  "name": "4 · Auto: Git Sync Push",
  "description": "Automatically pushes changes to the personal GitHub repo after every agent session completes. Keeps the local machine in sync with the container.",
  "version": "1",
  "when": {
    "type": "agentStop"
  },
  "then": {
    "type": "runCommand",
    "command": "~/shared/tools/git-sync/sync.sh push",
    "timeout": 30
  }
}