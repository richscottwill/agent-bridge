{
  "enabled": true,
  "name": "Open Items Reminder",
  "description": "Every 3 hours (conversation-gated), scan session-log.md for OPEN/deferred items and DUE-dated reminders within 14 days. Surfaces as a compact 2-3 line prepend.",
  "version": "4",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "askAgent",
    "prompt": "Execute the open-items scan per ~/shared/context/protocols/open-items-scan.md. If already run this conversation, skip silently. Non-blocking."
  }
}
