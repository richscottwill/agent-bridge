{
  "name": "Dashboard Server Keepalive",
  "version": "1.0.0",
  "description": "Ensures the dashboard HTTP server is running on port 8080. Checks on every prompt — if the server died (container recycle, idle timeout), restarts it silently.",
  "when": {
    "type": "promptSubmit"
  },
  "then": {
    "type": "runCommand",
    "command": "if ! lsof -i :8080 -sTCP:LISTEN >/dev/null 2>&1; then ( cd ~/shared/dashboards && setsid nohup python3 -m http.server 8080 > server.log 2>&1 < /dev/null & ); echo 'Dashboard server restarted on :8080'; else echo 'Dashboard server already running'; fi"
  }
}